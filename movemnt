local function CreateSlider(labelText, yPos, minVal, maxVal, initialValue, onChanged)
    local h = Instance.new("Frame", Main)
    h.Size = UDim2.new(0.9, 0, 0, 42)
    h.Position = UDim2.new(0.05, 0, 0, yPos)
    h.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
    Instance.new("UICorner", h).CornerRadius = UDim.new(0, 8)

