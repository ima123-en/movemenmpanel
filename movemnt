    if dragging and not isInteractingWithSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- Status Loop
task.spawn(function()
    while ScreenGui and ScreenGui.Parent do
        if _G.invisibleStealEnabled then
            StatusText.Text = string.format("Invis Active (%.1f° / depth %.1f)", _G.InvisStealAngle, _G.SinkSliderValue)
            StatusDot.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
        else
            StatusText.Text = "Idle"
            StatusDot.BackgroundColor3 = Color3.fromRGB(100, 100, 110)
        end
        task.wait(1/30)
    end
end)
