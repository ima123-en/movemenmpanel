            if data.DepthOffset then MS.DepthOffset = data.DepthOffset end
            if data.SemiInvisKey then MS.SemiInvisKey = data.SemiInvisKey end
            if data.SpeedBoostKey then MS.SpeedBoostKey = data.SpeedBoostKey end
        end
    end)
end

