            writefile(SAVE_KEY .. ".json", HttpService:JSONEncode({
                SemiInvisEnabled = MS.SemiInvisEnabled,
                SemiInvisStealEnabled = MS.SemiInvisStealEnabled,
                SpeedBoostEnabled = MS.SpeedBoostEnabled,
                NoAnimEnabled = MS.NoAnimEnabled,
