        local mbgc = a and Color3.fromRGB(55, 55, 65) or Color3.fromRGB(35, 35, 40)
        local tc = a and Color3.fromRGB(220, 220, 230) or Color3.fromRGB(170, 170, 180)
        if inst then
            c.Position = pos c.BackgroundColor3 = bgc bg.BackgroundColor3 = mbgc l.TextColor3 = tc
        else
            TweenService:Create(c, TweenInfo.new(0.2), {Position = pos, BackgroundColor3 = bgc}):Play()
            TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = mbgc}):Play()
            TweenService:Create(l, TweenInfo.new(0.2), {TextColor3 = tc}):Play()
        end
    end

    upd(getState(), true)
    b.MouseButton1Click:Connect(function()
        local newState = not getState()
        onToggle(newState)
        upd(newState, false)
    end)
    kb.MouseButton1Click:Connect(function() onKeyBindFocus(kb) end)

    return upd, kb
end

local function CreateSlider(labelText, yPos, minVal, maxVal, initialValue, onChanged)
    local h = Instance.new("Frame", Main)
    h.Size = UDim2.new(0.9, 0, 0, 42)
    h.Position = UDim2.new(0.05, 0, 0, yPos)
    h.BackgroundColor3 = Color3.fromRGB(20, 20, 24)
    Instance.new("UICorner", h).CornerRadius = UDim.new(0, 8)

    local l = Instance.new("TextLabel", h)
    l.Size = UDim2.new(0.4, 0, 1, 0)
    l.Position = UDim2.new(0, 12, 0, 0)
    l.BackgroundTransparency = 1
    l.Text = labelText
    l.Font = Enum.Font.Gotham
    l.TextSize = 14
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.TextColor3 = Color3.fromRGB(170, 170, 180)

    local bar = Instance.new("Frame", h)
    bar.Size = UDim2.new(0, 120, 0, 6)
    bar.Position = UDim2.new(0, 120, 0.5, -3)
    bar.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    bar.BorderSizePixel = 0
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame", bar)
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.Position = UDim2.new(0, 0, 0, 0)
    fill.BackgroundColor3 = Color3.fromRGB(200, 200, 210)
    fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame", bar)
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.Position = UDim2.new(0, -6, 0.5, -6)
    knob.BackgroundColor3 = Color3.fromRGB(230, 230, 235)
    knob.BorderSizePixel = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local valueLabelBG = Instance.new("Frame", h)
    valueLabelBG.Size = UDim2.new(0, 50, 0, 20)
    valueLabelBG.Position = UDim2.new(1, -58, 0.5, -10)
    valueLabelBG.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    valueLabelBG.BorderSizePixel = 0
    Instance.new("UICorner", valueLabelBG).CornerRadius = UDim.new(0, 4)

    local valueLabel = Instance.new("TextLabel", valueLabelBG)
    valueLabel.Size = UDim2.new(1, 0, 1, 0)
    valueLabel.Position = UDim2.new(0, 0, 0, 0)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = tostring(initialValue)
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 13
    valueLabel.TextColor3 = Color3.fromRGB(200, 200, 210)
    valueLabel.TextXAlignment = Enum.TextXAlignment.Center

    local dragging = false
    local currentValue = math.clamp(initialValue, minVal, maxVal)

    local function setFromAlpha(a, instant)
        a = math.clamp(a, 0, 1)
        local value = minVal + (maxVal - minVal) * a
        value = math.floor(value * 10 + 0.5) / 10
        currentValue = value
        valueLabel.Text = tostring(value)

        local sizeX = bar.AbsoluteSize.X
        if sizeX <= 0 then return end
        local x = a * sizeX

        if instant then
            fill.Size = UDim2.new(0, x, 1, 0)
            knob.Position = UDim2.new(0, x - 6, 0.5, -6)
        else
            TweenService:Create(fill, TweenInfo.new(0.1), {Size = UDim2.new(0, x, 1, 0)}):Play()
            TweenService:Create(knob, TweenInfo.new(0.1), {Position = UDim2.new(0, x - 6, 0.5, -6)}):Play()
        end

        onChanged(value)
    end

    local function updateFromX(px)
        local absPos = bar.AbsolutePosition.X
        local sizeX = bar.AbsoluteSize.X
        if sizeX <= 0 then return end
        local alpha = (px - absPos) / sizeX
        setFromAlpha(alpha, false)
    end

    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateFromX(input.Position.X)
        end
    end)

    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateFromX(input.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    task.defer(function()
        local alpha = (currentValue - minVal) / (maxVal - minVal)
        setFromAlpha(alpha, true)
    end)

    local function setValueExternal(v)
        currentValue = math.clamp(v, minVal, maxVal)
        local alpha = (currentValue - minVal) / (maxVal - minVal)
        task.defer(function()
            setFromAlpha(alpha, true)
        end)
    end

    return setValueExternal
end

