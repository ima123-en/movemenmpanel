                BodyAngle = MS.BodyAngle,
                DepthOffset = MS.DepthOffset,
                SemiInvisKey = MS.SemiInvisKey,
                SpeedBoostKey = MS.SpeedBoostKey
            }))
        end
    end)
end

local function LoadSettings()
    pcall(function()
        if readfile and isfile and isfile(SAVE_KEY .. ".json") then
            local data = HttpService:JSONDecode(readfile(SAVE_KEY .. ".json"))
            if data.SemiInvisEnabled ~= nil then MS.SemiInvisEnabled = data.SemiInvisEnabled end
            if data.SemiInvisStealEnabled ~= nil then MS.SemiInvisStealEnabled = data.SemiInvisStealEnabled end
