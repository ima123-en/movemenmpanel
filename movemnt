UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    
    if waitingForSemiInvisKey and input.UserInputType == Enum.UserInputType.Keyboard then
        waitingForSemiInvisKey = false
        local keyName = input.KeyCode.Name
        if keyName and keyName ~= "Unknown" then
            MS.SemiInvisKey = keyName
            if semiInvisKeyBtn then
                semiInvisKeyBtn.Text = keyName
            end
            SaveSettings()
        else
            if semiInvisKeyBtn then
                semiInvisKeyBtn.Text = MS.SemiInvisKey
            end
        end
        return
    end

    if waitingForSpeedKey and input.UserInputType == Enum.UserInputType.Keyboard then
        waitingForSpeedKey = false
        local keyName = input.KeyCode.Name
        if keyName and keyName ~= "Unknown" then
            MS.SpeedBoostKey = keyName
            speedKeyBtn.Text = keyName
            SaveSettings()
        else
            speedKeyBtn.Text = MS.SpeedBoostKey
        end
        return
    end
    
    if input.UserInputType == Enum.UserInputType.Keyboard then
        local semiKeyCode = Enum.KeyCode[MS.SemiInvisKey]
        if semiKeyCode and input.KeyCode == semiKeyCode then
            local newState = not MS.SemiInvisEnabled
            if newState then
                EnableSemiInvis()
            else
                DisableSemiInvis(true)
            end
        end

        local speedKeyCode = Enum.KeyCode[MS.SpeedBoostKey]
        if speedKeyCode and input.KeyCode == speedKeyCode then
            local newState = not MS.SpeedBoostEnabled
            MS.SpeedBoostEnabled = newState
            if newState then
                EnableSpeedBoost()
            else
                DisableSpeedBoost()
            end
            speedBoostUpdate(newState, false)
            SaveSettings()
        end
    end
end)

