local function SaveSettings()
    pcall(function()
        if writefile then
            writefile(SAVE_KEY .. ".json", HttpService:JSONEncode({
                SemiInvisStealEnabled = MS.SemiInvisStealEnabled,
                SpeedBoostEnabled = MS.SpeedBoostEnabled,
                NoAnimEnabled = MS.NoAnimEnabled,
                StealSpeed = MS.StealSpeed,
                BodyAngle = MS.BodyAngle,
                SpeedBoostKey = MS.SpeedBoostKey
            }))
        end
    end)
end

local function LoadSettings()
    pcall(function()
        if readfile and isfile and isfile(SAVE_KEY .. ".json") then
            local data = HttpService:JSONDecode(readfile(SAVE_KEY .. ".json"))
            if data.SemiInvisStealEnabled ~= nil then MS.SemiInvisStealEnabled = data.SemiInvisStealEnabled end
            if data.SpeedBoostEnabled ~= nil then MS.SpeedBoostEnabled = data.SpeedBoostEnabled end
            if data.NoAnimEnabled ~= nil then MS.NoAnimEnabled = data.NoAnimEnabled end
            if data.StealSpeed then MS.StealSpeed = data.StealSpeed end
            if data.BodyAngle then MS.BodyAngle = data.BodyAngle end
            if data.SpeedBoostKey then MS.SpeedBoostKey = data.SpeedBoostKey end
        end
    end)
end

