StatusText.Parent = StatusBar

-- Keybind handling
local waitingForSpeedKey = false

speedKeyBtn.MouseButton1Click:Connect(function()
    waitingForSpeedKey = true
    speedKeyBtn.Text = "..."
end)

-- Toggle connections
semiInvisStealBtn.MouseButton1Click:Connect(function()
    MS.SemiInvisStealEnabled = not MS.SemiInvisStealEnabled
    if MS.SemiInvisStealEnabled then
        StartStealDetection()
    else
        StopStealDetection()
    end
    semiInvisStealUpdate(MS.SemiInvisStealEnabled)
    SaveSettings()
end)

noAnimBtn.MouseButton1Click:Connect(function()
    MS.NoAnimEnabled = not MS.NoAnimEnabled
    if MS.NoAnimEnabled then
        EnableNoAnim()
    else
        DisableNoAnim()
    end
    noAnimUpdate(MS.NoAnimEnabled)
    SaveSettings()
end)

-- Input handling
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    
    if waitingForSpeedKey and input.UserInputType == Enum.UserInputType.Keyboard then
        waitingForSpeedKey = false
        local keyName = input.KeyCode.Name
        if keyName and keyName ~= "Unknown" then
            MS.SpeedBoostKey = keyName
            speedKeyBtn.Text = keyName
            SaveSettings()
        else
            speedKeyBtn.Text = MS.SpeedBoostKey
        end
        return
    end
    
    if input.UserInputType == Enum.UserInputType.Keyboard then
        local keyCode = Enum.KeyCode[MS.SpeedBoostKey]
        if keyCode and input.KeyCode == keyCode then
            SpeedBoostKeyHeld = true
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Keyboard then
        local keyCode = Enum.KeyCode[MS.SpeedBoostKey]
        if keyCode and input.KeyCode == keyCode then
            SpeedBoostKeyHeld = false
        end
    end
end)

-- Dragging
local dragging, dragStart, startPos
Main.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = i.Position
        startPos = Main.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- Character handling
LocalPlayer.CharacterAdded:Connect(function(char)
    CleanupStealInvis()
    lastWalkSpeed = 100
    isWaitingForDelay = false
    stealStartTime = 0
    godmodeSetup = false
    
    local hum = char:WaitForChild("Humanoid", 10)
    if hum then
        hum.Seated:Connect(function(isSeated)
            if isSeated then
                isWaitingForDelay = false
                stealStartTime = 0
                if stealInvisActive then
                    CleanupStealInvis()
                end
            end
        end)
    end
end)

if LocalPlayer.Character then
    local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum then
        hum.Seated:Connect(function(isSeated)
            if isSeated then
                isWaitingForDelay = false
                stealStartTime = 0
                if stealInvisActive then
                    CleanupStealInvis()
                end
            end
        end)
    end
end

-- Status update loop
task.spawn(function()
    while ScreenGui and ScreenGui.Parent do
        if stealInvisActive then
            StatusText.Text = "Semi Invis (" .. MS.BodyAngle .. "°)"
            StatusDot.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
        elseif SpeedBoostKeyHeld then
            StatusText.Text = "Speed Boost"
            StatusDot.BackgroundColor3 = Color3.fromRGB(200, 200, 100)
        elseif isWaitingForDelay then
            StatusText.Text = "Waiting..."
            StatusDot.BackgroundColor3 = Color3.fromRGB(200, 150, 100)
        else
            StatusText.Text = "Idle"
            StatusDot.BackgroundColor3 = Color3.fromRGB(100, 100, 110)
        end
        task.wait(1/30)
    end
end)

-- Initialize from saved settings
if MS.SemiInvisStealEnabled then
    StartStealDetection()
end

if MS.NoAnimEnabled then
    EnableNoAnim()
end

EnableSpeedBoost()

function MS.Disable()
    StopStealDetection()
    DisableSpeedBoost()
    DisableNoAnim()
    SaveSettings()
    for _, conn in pairs(MS.Connections) do
        if conn then pcall(function() conn:Disconnect() end) end
    end
    if ScreenGui then
        ScreenGui:Destroy()
    end
end
