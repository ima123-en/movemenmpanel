local function CleanupStealInvis()
    stealInvisActive = false
    isWaitingForDelay = false
    stealStartTime = 0
    
    if stealFaixaAnimacao then
        pcall(function()
            stealFaixaAnimacao:Stop()
            stealFaixaAnimacao:Destroy()
        end)
        stealFaixaAnimacao = nil
    end
    
    if stealUpdateConnection then
        pcall(function() stealUpdateConnection:Disconnect() end)
        stealUpdateConnection = nil
    end
    
    if stealHealthConnection then
        pcall(function() stealHealthConnection:Disconnect() end)
        stealHealthConnection = nil
    end
    
    if stealRaizAntiga and stealClone and LocalPlayer.Character then
        pcall(function()
            local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
            if not stealRaizAntiga:IsDescendantOf(game) then
                stealClone = nil
                stealRaizAntiga = nil
                stealQuadril = nil
                DisableGodmode()
                return
            end
            
            local currentCFrame = stealClone.CFrame
            local currentVelocity = stealClone.AssemblyLinearVelocity or Vector3.zero
            
            local paiTemporario = Instance.new("Model")
            paiTemporario.Parent = game
            LocalPlayer.Character.Parent = paiTemporario
            stealRaizAntiga.Parent = LocalPlayer.Character
            LocalPlayer.Character.PrimaryPart = stealRaizAntiga
            LocalPlayer.Character.Parent = game.Workspace
            stealRaizAntiga.CanCollide = true
            
            for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
                if v:IsA("Weld") or v:IsA("Motor6D") then
                    if v.Part0 == stealClone then v.Part0 = stealRaizAntiga end
                    if v.Part1 == stealClone then v.Part1 = stealRaizAntiga end
                end
            end
            
            stealClone:Destroy()
            stealRaizAntiga.CFrame = currentCFrame
            stealRaizAntiga.AssemblyLinearVelocity = currentVelocity
            stealRaizAntiga.AssemblyAngularVelocity = Vector3.zero
            
            paiTemporario:Destroy()
            if hum then hum.HipHeight = stealQuadril or 2 end
        end)
    end
    
    stealClone = nil
    stealRaizAntiga = nil
    stealQuadril = nil
    DisableGodmode()
    RemoveFolders()
end

local function PlayStealAnimation()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return end
    
    pcall(function()
        local anim = Instance.new("Animation")
        anim.AnimationId = "http://www.roblox.com/asset/?id=18537363391"
        local animator = hum:FindFirstChild("Animator") or Instance.new("Animator", hum)
        stealFaixaAnimacao = animator:LoadAnimation(anim)
        stealFaixaAnimacao.Priority = Enum.AnimationPriority.Action4
        stealFaixaAnimacao:Play(0, 1, 0)
        anim:Destroy()
        
        local animStoppedConn
        animStoppedConn = stealFaixaAnimacao.Stopped:Connect(function()
            if stealInvisActive and not IsSeated() then task.defer(PlayStealAnimation) end
        end)
        table.insert(MS.Connections, animStoppedConn)
        
        task.defer(function()
            if stealFaixaAnimacao then
                stealFaixaAnimacao.TimePosition = 0.7
                task.delay(1, function()
                    if stealFaixaAnimacao then pcall(function() stealFaixaAnimacao:AdjustSpeed(math.huge) end) end
                end)
            end
        end)
    end)
end

local function ActivateStealInvis()
    if stealInvisActive or IsSeated() then return false end
    if not LocalPlayer.Character then return false end
    
    local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    if not hum or not hrp or hum.Health <= 0 or hum.Sit then return false end
    
    RemoveFolders()
    SetupGodmode()
    
    stealQuadril = hum.HipHeight
    stealRaizAntiga = hrp

    local paiTemporario = Instance.new("Model")
    paiTemporario.Parent = game
    LocalPlayer.Character.Parent = paiTemporario
    stealClone = stealRaizAntiga:Clone()
    stealClone.Parent = LocalPlayer.Character
    stealRaizAntiga.Parent = game.Workspace.CurrentCamera
    stealClone.CFrame = stealRaizAntiga.CFrame
    LocalPlayer.Character.PrimaryPart = stealClone
    LocalPlayer.Character.Parent = game.Workspace
    
    for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
        if v:IsA("Weld") or v:IsA("Motor6D") then
            if v.Part0 == stealRaizAntiga then v.Part0 = stealClone end
            if v.Part1 == stealRaizAntiga then v.Part1 = stealClone end
        end
    end
    paiTemporario:Destroy()

    stealInvisActive = true
    
    stealHealthConnection = hum.HealthChanged:Connect(function(newHealth)
        if stealInvisActive and newHealth <= 0 then hum.Health = hum.MaxHealth end
    end)
    
    task.delay(0.1, function()
        if stealInvisActive then PlayStealAnimation() end
    end)

    stealUpdateConnection = RunService.PreSimulation:Connect(function()
        if not stealInvisActive then return end
        if IsSeated() then
            task.defer(CleanupStealInvis)
            return
        end
        local char = LocalPlayer.Character
        if not char then return end
        local h = char:FindFirstChild("Humanoid")
        if not h or not stealRaizAntiga or not stealRaizAntiga.Parent or not stealClone or not stealClone.Parent then return end
        
        if h.Health <= 1 then h.Health = h.MaxHealth end
        
        local raiz = stealClone
        if raiz then
            local cf = raiz.CFrame - Vector3.new(0, h.HipHeight + (raiz.Size.Y / 2) - 1 + DEPTH_OFFSET, 0)
            stealRaizAntiga.CFrame = cf * CFrame.Angles(math.rad(MS.BodyAngle), 0, 0)
            stealRaizAntiga.AssemblyLinearVelocity = raiz.AssemblyLinearVelocity
            stealRaizAntiga.AssemblyAngularVelocity = Vector3.zero
            stealRaizAntiga.CanCollide = false
        end
    end)

    return true
end

local function StartStealDetection()
    if stealDetectionConnection then return end
    lastWalkSpeed = 100
    stealStartTime = 0
    isWaitingForDelay = false
    
    stealDetectionConnection = RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChild("Humanoid")
        if not hum then return end
        
        if hum.Sit then
            if stealInvisActive then CleanupStealInvis() end
            isWaitingForDelay = false
            stealStartTime = 0
            lastWalkSpeed = hum.WalkSpeed
            return
        end
        
        local currentWalkSpeed = hum.WalkSpeed
        local isStealing = currentWalkSpeed <= 25
        local wasStealing = lastWalkSpeed <= 25
        
        if isStealing and not wasStealing then
            stealStartTime = tick()
            isWaitingForDelay = true
        end
        
        if isWaitingForDelay and isStealing then
            if tick() - stealStartTime >= STEAL_DELAY then
                isWaitingForDelay = false
                if not stealInvisActive and not hum.Sit then ActivateStealInvis() end
            end
        end
        
        if not isStealing and wasStealing then
            isWaitingForDelay = false
            stealStartTime = 0
            if stealInvisActive then CleanupStealInvis() end
        end
        
        if not isStealing and isWaitingForDelay then
            isWaitingForDelay = false
            stealStartTime = 0
        end
        
        lastWalkSpeed = currentWalkSpeed
    end)
end

local function StopStealDetection()
    if stealDetectionConnection then
        stealDetectionConnection:Disconnect()
        stealDetectionConnection = nil
    end
    isWaitingForDelay = false
    stealStartTime = 0
    if stealInvisActive then CleanupStealInvis() end
    lastWalkSpeed = 100
end

local function EnableSpeedBoost()
    if SpeedConnection then return end
    SpeedConnection = RunService.Heartbeat:Connect(function()
        if not MS.SpeedBoostEnabled then return end
        local char = LocalPlayer.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not root or not hum or hum.Health <= 0 then return end

        local state = hum:GetState()
        if state == Enum.HumanoidStateType.Physics or state == Enum.HumanoidStateType.Ragdoll or state == Enum.HumanoidStateType.FallingDown then return end
        if hum.WalkSpeed > 25 or hum.Sit then return end

        local moveDir = hum.MoveDirection
        if moveDir.Magnitude > 0.1 then
            local dir = moveDir.Unit
            root.AssemblyLinearVelocity = Vector3.new(dir.X * MS.StealSpeed, root.AssemblyLinearVelocity.Y, dir.Z * MS.StealSpeed)
        end
    end)
end

local function DisableSpeedBoost()
    if SpeedConnection then
        SpeedConnection:Disconnect()
        SpeedConnection = nil
    end
end

local function EnableNoAnim()
    if NoAnimLoop then return end
    NoAnimLoop = RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChild("Humanoid")
        if not hum then return end
        local animator = hum:FindFirstChild("Animator")
        if not animator then return end

        for _, track in pairs(animator:GetPlayingAnimationTracks()) do
            if track.IsPlaying and track ~= stealFaixaAnimacao then
                track:AdjustSpeed(0)
            end
        end
    end)
end

local function DisableNoAnim()
    if NoAnimLoop then
        NoAnimLoop:Disconnect()
        NoAnimLoop = nil
    end
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if hum then
            local animator = hum:FindFirstChild("Animator")
            if animator then
                for _, track in pairs(animator:GetPlayingAnimationTracks()) do track:AdjustSpeed(1) end
            end
        end
    end
end

